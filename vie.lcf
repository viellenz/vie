YouTube = select,节点选择,US,HK,JP,TW,SG,KR,其余节点,DIRECT,img-url = https://raw.githubusercontent.com/Semporia/Hand-Painted-icon/master/Google_Suite/YouTube.png
Spotify = select,节点选择,US,HK,JP,TW,SG,KR,其余节点,img-url = https://raw.githubusercontent.com/luestr/IconResource/main/App_icon/120px/Spotify.png
Microsoft = select,DIRECT,节点选择,US,HK,JP,TW,SG,KR,其余节点,img-url = https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/Microsoft.png
Apple = select,DIRECT,节点选择,US,HK,JP,TW,SG,KR,其余节点,img-url = https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/master/icon/qure/color/Apple.png
